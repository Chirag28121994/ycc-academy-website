---
// Clean Responsive Navigation Layout
import { SITE } from '../config';
---
<header class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-xs">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="font-bold text-xl tracking-tight text-slate-950 flex items-center gap-2">
      🔥 <span class="text-blue-800">{SITE.name.split(' ')[0]}</span> {SITE.name.split(' ')[1] || ''}
    </a>
    <nav class="flex gap-6 text-sm font-semibold text-slate-600">
      <a href="/" class="hover:text-blue-800 transition-colors">Home</a>
      <a href="/junior" class="hover:text-blue-800 transition-colors">5th - 10th</a>
      <a href="/senior" class="hover:text-blue-800 transition-colors">11th & 12th</a>
    </nav>
  </div>
</header>