---
// WhatsApp Floating Button Component
import { CONTACT } from '../config';
const whatsappNumber = CONTACT.primary.whatsappCode;
const prefilledText = encodeURIComponent(CONTACT.whatsappPrefill);
---
<a
  href={`https://wa.me/${whatsappNumber}?text=${prefilledText}`}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 bg-green-500 hover:bg-green-600 text-white p-4 rounded-full shadow-2xl z-50 transition-transform hover:scale-110 flex items-center justify-center gap-2"
  aria-label="Chat on WhatsApp"
>
  <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.503-5.714-1.458L0 24zm6.59-4.846c1.6.95 3.488 1.451 5.414 1.452 5.378 0 9.757-4.379 9.76-9.76.002-2.606-1.01-5.057-2.852-6.901C17.127 2.099 14.68 1.085 12.071 1.085c-5.383 0-9.763 4.38-9.766 9.763-.001 1.897.5 3.743 1.452 5.347L2.748 21.6l5.899-1.546z"/>
  </svg>
  <span class="hidden md:inline font-semibold text-sm">Inquire on WhatsApp</span>
</a>