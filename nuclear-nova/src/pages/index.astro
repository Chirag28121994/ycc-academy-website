---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, CONTACT } from '../config';

const formEmbedUrl = SITE.googleFormUrl.replace('forms.gle/', 'docs.google.com/forms/d/e/').replace(/([a-zA-Z0-9_-]{20,})$/, '$1/viewform?embedded=true');

const highlights = [
  { title: "Experienced Faculty", desc: "Learn from top subject matter expert teachers dedicated to school board excellence." },
  { title: "Digital Classes", desc: "Interactive television visual concepts inside modern air-conditioned classrooms." },
  { title: "Weekly & Monthly Tests", desc: "Consistent track monitoring to ensure students are completely exam ready." },
  { title: "Dedicated Revision Sessions", desc: "Comprehensive revisions of critical topics before final terminal board exams." }
];

const faqs = [
  { q: "Where is YCC Academy located?", a: "We are situated right opposite the Sabzi Mandi at Karnal ki Bagiya, Pinto Park, Gwalior." },
  { q: "Does the academy provide support for both CBSE and MP Board?", a: "Yes, we run separate batches tailored specifically to the syllabus constraints of both boards." },
  { q: "Can we sign up for free demo classes?", a: "Absolutely! Every student is invited to attend free demo classes to experience our teaching approach first-hand." }
];
---

<BaseLayout title={`Best Coaching Classes for 5th-12th in ${SITE.locationShort}`}>
  <section class="relative bg-gradient-to-br from-blue-900 to-indigo-950 text-white py-20 px-4">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="bg-amber-500 text-slate-900 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">{SITE.admissionStatus}</span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mt-4 leading-tight">{SITE.name} <br/><span class="text-amber-400">{SITE.fullName}</span></h1>
        <p class="text-slate-300 mt-4 text-base sm:text-lg">{SITE.description}</p>
        <div class="mt-8 flex flex-col sm:flex-row flex-wrap gap-4">
          <a href={`https://wa.me/${CONTACT.secondary.whatsappCode}`} class="bg-amber-500 text-slate-900 px-6 py-3 rounded-lg font-bold hover:bg-amber-400 transition-colors text-center">Book Free Demo Class</a>
          <a href="#register" class="border border-slate-400 text-white px-6 py-3 rounded-lg font-bold hover:bg-white/10 transition-colors text-center">Fill Admission Inquiry</a>
        </div>
      </div>
      <div class="bg-slate-800 h-64 md:h-96 rounded-2xl shadow-xl border border-slate-700 flex items-center justify-center overflow-hidden">
        <span class="text-slate-500 text-sm p-4 text-center">[Place Digital Classroom Image here: assets/hero-classroom.webp]</span>
      </div>
    </div>
  </section>

  <section class="py-16 max-w-6xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12">Why Choose {SITE.name}?</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {highlights.map(h => (
        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600 font-bold text-xl mb-4">✓</div>
          <h3 class="font-bold text-lg text-slate-800">{h.title}</h3>
          <p class="text-slate-600 text-sm mt-2 leading-relaxed">{h.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-slate-100 py-12 px-4 border-y border-slate-200">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <h3 class="text-xl font-bold text-slate-800">Want the full offline course fee chart?</h3>
        <p class="text-slate-600 text-sm mt-1">Download the digital version of our printed flyer pamphlet to save on your phone.</p>
      </div>
      <a href={`${import.meta.env.BASE_URL}/assets/ycc-academy-brochure.pdf`} download class="bg-blue-700 hover:bg-blue-800 text-white font-bold px-6 py-3 rounded-lg flex items-center gap-2 whitespace-nowrap transition-colors">
        📥 Download Digital Pamphlet
      </a>
    </div>
  </section>

  <!-- ═══════════ ADMISSION INQUIRY FORM ═══════════ -->
  <section id="register" class="relative py-20 px-4 overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-blue-900 via-indigo-900 to-slate-900 pointer-events-none"></div>
    <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 20% 50%, #fbbf24 0%, transparent 50%), radial-gradient(circle at 80% 20%, #60a5fa 0%, transparent 50%);"></div>

    <div class="relative max-w-6xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-12">
        <span class="inline-block bg-amber-400/20 text-amber-300 text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-widest border border-amber-400/30 mb-4">Admissions 2026–27 Open</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Student Admission Enquiry</h2>
        <p class="text-slate-300 max-w-xl mx-auto text-base">Can't visit us in person right now? Fill out this quick form — Atul Sir or Vikash Sir will get back to you within 24 hours.</p>
      </div>

      <!-- Split layout: Trust signals + Form -->
      <div class="grid lg:grid-cols-5 gap-8 items-start">

        <!-- Left: Trust signals -->
        <div class="lg:col-span-2 space-y-5">
          <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6 text-white">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl">⚡</span>
              <h3 class="font-bold text-lg">Quick Response</h3>
            </div>
            <p class="text-slate-300 text-sm leading-relaxed">Our faculty personally reviews every inquiry and responds within 24 hours — even on weekends.</p>
          </div>

          <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6 text-white">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl">🎓</span>
              <h3 class="font-bold text-lg">Free Demo Class</h3>
            </div>
            <p class="text-slate-300 text-sm leading-relaxed">Every enquiry includes an invitation to a free demo class — experience our teaching style before committing.</p>
          </div>

          <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-2xl p-6 text-white">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-2xl">🔒</span>
              <h3 class="font-bold text-lg">Your Data is Safe</h3>
            </div>
            <p class="text-slate-300 text-sm leading-relaxed">We only use your details to get in touch about admissions. No spam, no sharing with third parties.</p>
          </div>

          <!-- Direct contact CTA -->
          <div class="bg-amber-500/20 border border-amber-400/30 rounded-2xl p-5 text-center">
            <p class="text-amber-300 text-sm font-semibold mb-3">Prefer to call directly?</p>
            <div class="space-y-2">
              <a href={`tel:${CONTACT.primary.phone.replace(/ /g, '')}`} class="flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold text-sm py-2.5 px-4 rounded-lg transition-colors">
                📞 {CONTACT.primary.name}: {CONTACT.primary.phone}
              </a>
              <a href={`tel:${CONTACT.secondary.phone.replace(/ /g, '')}`} class="flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold text-sm py-2.5 px-4 rounded-lg border border-white/20 transition-colors">
                📞 {CONTACT.secondary.name}: {CONTACT.secondary.phone}
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Google Form iframe -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-2xl shadow-2xl overflow-hidden border border-white/10">
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-4 flex items-center gap-3">
              <span class="text-2xl">📋</span>
              <div>
                <p class="text-white font-bold text-base">Admission Enquiry Form</p>
                <p class="text-blue-200 text-xs">Powered by Google Forms — secure &amp; instant</p>
              </div>
            </div>
            <div class="overflow-x-auto">
              <iframe
                src={SITE.googleFormUrl}
                width="100%"
                height="720"
                frameborder="0"
                marginheight="0"
                marginwidth="0"
                loading="lazy"
                title="YCC Academy Student Admission Enquiry Form"
              >Loading Google Form...</iframe>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════ GOOGLE MAPS LOCATION ═══════════ -->
  <section class="py-16 px-4 bg-slate-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-10">
        <span class="inline-block bg-blue-100 text-blue-700 text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-widest mb-4">Find Us</span>
        <h2 class="text-3xl font-bold text-slate-900 mb-3">Our Location</h2>
        <p class="text-slate-600 max-w-lg mx-auto text-sm leading-relaxed">
          📍 {SITE.address}
        </p>
        <a
          href={SITE.googleMapsShareUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-4 bg-blue-700 hover:bg-blue-800 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          Open in Google Maps
        </a>
      </div>

      <!-- Map embed -->
      <div class="rounded-2xl overflow-hidden shadow-lg border border-slate-200" style="height: 420px;">
        <iframe
          src={`https://maps.google.com/maps?q=Karnal+ki+Bagiya,+Pinto+Park,+Gwalior,+Madhya+Pradesh+474001&output=embed&z=15`}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="YCC Academy Location — Pinto Park, Gwalior"
        ></iframe>
      </div>
    </div>
  </section>

  <section class="bg-blue-50 py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">What Parents & Students Say</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white p-6 rounded-xl shadow-sm italic text-slate-700">
          "The separate batch structure for CBSE students helped me focus cleanly on my board patterns. Atul Sir makes complex math topics incredibly easy to digest."
          <div class="mt-4 font-bold text-slate-900 not-italic text-sm">— 10th Class CBSE Student Batch</div>
        </div>
        <div class="bg-white p-6 rounded-xl shadow-sm italic text-slate-700">
          "Very clean discipline and focus near Pinto Park area. Monthly mock test sheets kept my daughter completely on track with her MP Board revisions."
          <div class="mt-4 font-bold text-slate-900 not-italic text-sm">— Satisfied Parent, Gwalior</div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 max-w-4xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faqs.map(faq => (
        <div class="bg-white p-6 rounded-lg border border-slate-200">
          <h4 class="font-bold text-lg text-slate-900 mb-2">❓ {faq.q}</h4>
          <p class="text-slate-600 text-sm leading-relaxed pl-6">{faq.a}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>